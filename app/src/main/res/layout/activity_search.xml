<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="#FAF8F3"
    android:padding="24dp">

    <EditText
        android:id="@+id/etSearchLocation"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Escribe una ciudad o dirección"
        android:padding="10dp"
        android:background="@drawable/bg_button_outer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="32dp"/>

    <Button
        android:id="@+id/btnConfirmSearch"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="Buscar Restaurantes"
        android:backgroundTint="#FF6600"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etSearchLocation" />

</androidx.constraintlayout.widget.ConstraintLayout>